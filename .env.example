# Database Configuration
DB_HOST=57.131.33.181
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=your_password_here
DB_NAME=trollzstorecom_tr0llz_db

# JWT Configuration
JWT_SECRET=trollz_store_jwt_secret_key_2026
JWT_EXPIRATION_HOURS=72

# Flask Configuration
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=4500

# Flutterwave Configuration
# Get your keys from: https://dashboard.flutterwave.com/settings/apis
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-your_public_key_here
FLUTTERWAVE_SECRET_KEY=FLWSECK-your_secret_key_here
FLUTTERWAVE_ENCRYPTION_KEY=your_encryption_key_here

# Sendbox API Configuration
# Get your API key from: https://developers.staging.sendbox.co/ (staging)
# or https://developers.sendbox.co/ (production)
SENDBOX_API_KEY=your_sendbox_api_key_here
SENDBOX_ENV=live  # Options: staging or live

